    COM_HVAMX4ED_GetIOErrorMessage,"(none)",Get error message string for I/O state

quadrupole_setup_procedure:
  description: "Step-by-step procedure to configure for quadrupole operation with channels 0 and 1"
  steps:
    step1_init:
      name: Initialize Communication
      actions:
        - "COM_HVAMX4ED_Open(portNumber=0, comNumber=<your_com_port>)"
        - "Optional: COM_HVAMX4ED_SetBaudRate(0, 115200)"
        - "Verify: COM_HVAMX4ED_GetMainState(0) should return STATE_ON (0x0000)"
        - "COM_HVAMX4ED_ResetCurrentConfig(0) to start clean"
    step2_oscillator:
      name: Configure Oscillator (sets RF frequency)
      formula: "Period = (100e6 / desired_frequency_Hz) - 2"
      example_1khz: "Period = (100e6 / 1000) - 2 = 99998"
      action: "COM_HVAMX4ED_SetOscillatorPeriod(0, Period)"
    step3_pulser0:
      name: Configure Pulser 0 (drives Switch Channel 0)
      width_formula: "Width = (duty_cycle * (Period + 2)) - 2"
      delay_value: 1
      example_50pct: "Width = (0.5 * 100000) - 2 = 49998"
      actions:
        - "COM_HVAMX4ED_SetPulserDelay(0, 0, 1)"
        - "COM_HVAMX4ED_SetPulserWidth(0, 0, Width)"
        - "COM_HVAMX4ED_SetPulserConfig(0, 0, 0x02) // Trigger=Osc0"
    step4_pulser1:
      name: Configure Pulser 1 (drives Switch Channel 1 - inverted for 180 deg phase)
      note: "Same width as Pulser 0 for symmetric signal. Trigger from PulsOut0 gives 180deg phase offset."
      actions:
        - "COM_HVAMX4ED_SetPulserDelay(0, 1, 1)"
        - "COM_HVAMX4ED_SetPulserWidth(0, 1, Width)"
        - "COM_HVAMX4ED_SetPulserConfig(0, 2, 0x0A) // Trigger=PulsOut0 (falling edge triggers Pulser1)"
    step5_switch_config:
      name: Configure Switch Controls
      actions:
        - "// Switch 0 trigger = PulsOut0"
        - "COM_HVAMX4ED_SetSwitchTriggerConfig(0, 0, 0x0A) // PulsOut0"
        - "// Switch 0 enable = inverted Logic0 (always on)"
        - "COM_HVAMX4ED_SetSwitchEnableConfig(0, 0, 0x20) // Logic0 inverted = always 1"
        - "// Switch 1 trigger = PulsOut1"
        - "COM_HVAMX4ED_SetSwitchTriggerConfig(0, 1, 0x0B) // PulsOut1"
        - "// Switch 1 enable = inverted Logic0 (always on)"
        - "COM_HVAMX4ED_SetSwitchEnableConfig(0, 1, 0x20) // Logic0 inverted = always 1"
    step6_dio_trigger_out:
      name: Configure DIO0 as oscilloscope trigger output
      actions:
        - "// Set DIO1 as output"
        - "COM_HVAMX4ED_SetInputConfig(0, 0x01, 0x00) // OutputEnable bit 0 = DIO1"
        - "// Assign DIO1 output to Osc0 signal"
        - "COM_HVAMX4ED_SetOutputConfig(0, 0, 0x02) // Osc0"
    step7_enable:
      name: Enable the system
      actions:
        - "// Enable switches + oscillator + pulsers"
        - "config = COM_HVAMX4ED_ENB | COM_HVAMX4ED_ENB_OSC | COM_HVAMX4ED_ENB_PULSER"
        - "COM_HVAMX4ED_SetControllerConfig(0, config) // 0x07"

verified_measurement:
  description: "Confirmed working measurement from actual hardware test"
  oscillator_period_register: 100000
  measured_frequency_hz: 1000
  measured_period_ms: 1.0
  pulser0_width_register: 50000
  calculated_duty_cycle: 0.5
  pulsers_1_2_3_width: 0
  note: "Only Pulser 0 was active in this configuration. Register values are in clock ticks of 100 MHz clock (10ns each)."

source_files:
  header: COM-HVAMX4ED.h
  manual: AMXCTRL4ED_100_2.pdf
  front_panel_photo: FrontPanel_Switch.jpg
  dll: COM-HVAMX4ED.dll
  lib: COM-HVAMX4ED.lib
  utility: COM-HVAMX4ED-Control.exe
  flash_loader: FlashLoader.exe

flash_loader:
  description: "Firmware upgrade utility"
  verify_command: "FlashLoader <port> Firmware.txt -$ -v"
  program_command: "FlashLoader <port> Firmware.txt -$"
  retry_command: "FlashLoader <port> Firmware.txt -$ -i"
  reset_command: "FlashLoader <port> -$ -i -f"
  warning: "Do NOT power down during firmware upgrade. Disconnect switch power cables before flashing."
  min_revision: "1-20"

utility_commands:
  start: "COM-HVAMX4ED-Control <port>"
  backup: "COM-HVAMX4ED-Control <port> -y FileName"
  restore: "COM-HVAMX4ED-Control <port> -Y FileName"
