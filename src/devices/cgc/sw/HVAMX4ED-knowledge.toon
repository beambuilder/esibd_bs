device_states:
  main_state[5]{hex_value,constant,description}:
    0x0000,COM_HVAMX4ED_STATE_ON,Device active
    0x8000,COM_HVAMX4ED_STATE_ERROR,Error bit
    0x8001,COM_HVAMX4ED_STATE_ERR_VSUP,Voltage failure
    0x8002,COM_HVAMX4ED_STATE_ERR_TEMP_LOW,Low-temperature failure
    0x8003,COM_HVAMX4ED_STATE_ERR_TEMP_HIGH,High-temperature failure
    0x8004,COM_HVAMX4ED_STATE_ERR_FPGA_DIS,Internal failure (FPGA disabled or unresponsive)
  device_state_bits[12]{bit,constant,description}:
    0x00,COM_HVAMX4ED_DEVST_VCPU_FAIL,CPU supply voltage failed
    0x01,COM_HVAMX4ED_DEVST_VSUP_FAIL,Fan supply voltage failed
    0x08,COM_HVAMX4ED_DEVST_FAN1_FAIL,Fan #1 failed
    0x09,COM_HVAMX4ED_DEVST_FAN2_FAIL,Fan #2 failed
    0x0A,COM_HVAMX4ED_DEVST_FAN3_FAIL,Fan #3 failed
    0x0F,COM_HVAMX4ED_DEVST_FPGA_DIS,FPGA disabled or unresponsive
    0x10,COM_HVAMX4ED_DEVST_SEN1_HIGH,Temperature sensor #1 hot
    0x11,COM_HVAMX4ED_DEVST_SEN2_HIGH,Temperature sensor #2 hot
    0x12,COM_HVAMX4ED_DEVST_SEN3_HIGH,Temperature sensor #3 hot
    0x18,COM_HVAMX4ED_DEVST_SEN1_LOW,Temperature sensor #1 cold
    0x19,COM_HVAMX4ED_DEVST_SEN2_LOW,Temperature sensor #2 cold
    0x1A,COM_HVAMX4ED_DEVST_SEN3_LOW,Temperature sensor #3 cold

controller_config_bits[11]{bit,constant,rw,description}:
  0,COM_HVAMX4ED_ENB,RW,"Enables switches; if PREVENT_DIS=0, clearing forces CLRn=0 resetting osc/pulsers and stopping PSUs"
  1,COM_HVAMX4ED_ENB_OSC,RW,Enables the oscillator
  2,COM_HVAMX4ED_ENB_PULSER,RW,Enables all pulse generators
  3,COM_HVAMX4ED_SW_TRIG,RW,Software trigger input
  4,COM_HVAMX4ED_SW_PULSE,RW,"1 creates a 1-CLK wide pulse at software trigger"
  5,COM_HVAMX4ED_PREVENT_DIS,RW,"Prevents CLRn=0 when ENB=0; only switches disabled, not PSUs"
  6,COM_HVAMX4ED_DIS_DITHER,RW,Disables dithering of internal switching regulators
  7,COM_HVAMX4ED_NC,NA,Bit not used
  8,COM_HVAMX4ED_ENABLE,RO,"Master enable; clearing forces CLRn=0"
  9,COM_HVAMX4ED_SW_TRIG_OUT,RO,Software-trigger engine output
  10,COM_HVAMX4ED_CLRN,RO,"Device enable output (CLRn), active low"

trigger_sources[20]{index,constant,signal,description}:
  0,COM_HVAMX4ED_CFG_LOG0,Logic0,"Logic 0, stop"
  1,COM_HVAMX4ED_CFG_SOFT_TRIG,SwTrig,Software trigger
  2,COM_HVAMX4ED_CFG_OSC0,Osc0,Output of oscillator #0
  3,COM_HVAMX4ED_CFG_DIN0,Din0,Digital input DIO1
  4,COM_HVAMX4ED_CFG_DIN1,Din1,Digital input DIO2
  5,COM_HVAMX4ED_CFG_DIN2,Din2,Digital input DIO3
  6,COM_HVAMX4ED_CFG_DIN3,Din3,Digital input DIO4
  7,COM_HVAMX4ED_CFG_DIN4,Din4,Digital input DIO5
  8,COM_HVAMX4ED_CFG_DIN5,Din5,Digital input DIO6
  9,COM_HVAMX4ED_CFG_DIN6,Din6,Digital input DIO7
  10,COM_HVAMX4ED_CFG_PULS_OUT0,PulsOut0,Output of pulse generator #0
  11,COM_HVAMX4ED_CFG_PULS_OUT1,PulsOut1,Output of pulse generator #1
  12,COM_HVAMX4ED_CFG_PULS_OUT2,PulsOut2,Output of pulse generator #2
  13,COM_HVAMX4ED_CFG_PULS_OUT3,PulsOut3,Output of pulse generator #3
  14,COM_HVAMX4ED_CFG_PULS_RUN0,PulsRun0,Running state of pulse generator #0
  15,COM_HVAMX4ED_CFG_PULS_RUN1,PulsRun1,Running state of pulse generator #1
  16,COM_HVAMX4ED_CFG_PULS_RUN2,PulsRun2,Running state of pulse generator #2
  17,COM_HVAMX4ED_CFG_PULS_RUN3,PulsRun3,Running state of pulse generator #3
  18,COM_HVAMX4ED_CFG_CLK2M,CLK2M,Internal quartz clock 2 MHz (output only)
  19,COM_HVAMX4ED_CFG_CLK4M,CLK4M,Internal quartz clock 4 MHz (output only)

config_bit_masks:
  CFG_MASK: 31
  CFG_INVERT: 32
  CONFIG_SIZE: 6
  CONFIG_MAX: 64
  SELECT_MASK: 31

pulser_config_assignment:
  description: "PulserCfgNo mapping for COM_HVAMX4ED_Get/SetPulserConfig"
  assignments[6]{cfg_no,function}:
    0,Trigger config of Pulser #0 (SelTrg0 and InvTrg0)
    1,Stop config of Pulser #0 (SelStp0 and InvStp0)
    2,Trigger config of Pulser #1 (SelTrg1 and InvTrg1)
    3,Stop config of Pulser #1 (SelStp1 and InvStp1)
    4,Trigger config of Pulser #2 (SelTrg2 and InvTrg2)
    5,Trigger config of Pulser #3 (SelTrg3 and InvTrg3)

switch_control:
  dual_level:
    description: "Each switch has trigger (SwTrgN) and enable (SwEnbN) inputs"
    truth_table[3]{trigger,enable,neg_branch,pos_branch}:
      X,0,off,off
      0,1,on,off
      1,1,off,on
  trilevel:
    description: "Two switch channels combined (0+1 or 2+3). First controls negative, second controls positive branch."
    note: "For normal operation both enable inputs must match (both high=on, both low=off)"
    switching: "Toggle both triggers synchronously between 0 and 1 to switch between Vneg and Vpos"
    middle_voltage: "SwTrig0/2=1 and SwTrig1/3=0 gives Vmid"
  delays:
    trigger_rise_fall_steps: 16
    trigger_delay_range_ns: "0-15 (approx 1ns resolution)"
    enable_delay_steps: 16
    enable_delay_range_ns: "0-15 (approx 1ns resolution)"
  mapping_engine:
    description: "Converts 4 control signals into different signal levels determined by Idle and State0-4 values"
    num_mappings: 5
    enable_bits: "Separate enable for trigger mapping and enable mapping"

dio_config:
  num_terminals: 7
  labels: "DIO1 through DIO7 on front panel (DIO0 also present)"
  modes[4]{output_enable,termination,mode}:
    0,0,"Input with 50kOhm pull-up (default)"
    0,1,"Input with 50 Ohm termination"
    1,X_0,Output 0
    1,X_1,Output 1
  notes:
    - "Digital inputs are always active regardless of DIO configuration"
    - "When configured as output, 5V amplitude with 50 Ohm internal impedance"
    - "With 50 Ohm termination output amplitude is 2.5V (TTL compatible)"
    - "DinN signal can monitor output function even when terminal is output"

