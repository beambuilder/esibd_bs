device:
  name: CGC HV-AMX-CTRL-4ED
  type: High-Voltage Power Switch 4x700V
  manufacturer: CGC Instruments
  address: "Hübschmannstr. 18, D-09112 Chemnitz"
  phone: +49 (371) 355 098-55
  fax: +49 (371) 355 098-60
  website: www.cgc-instruments.de
  dll_version: 1.00
  copyright: "CGC Instruments, (c) 2009-2021"

overview:
  purpose: Pulse controller that drives high-voltage power switches for applications like quadrupole mass spectrometry
  signal_chain: "Oscillator -> Pulse Generators -> Switch Control -> HV Output"
  amplitude_note: Amplitude is set by external PSUs and has nothing to do with the switch controller itself
  use_case: Driving opposing rod pairs in a quadrupole for mass selection and ion analysis
  front_panel_image: FrontPanel_Switch.jpg

front_panel:
  left_section:
    logo: CGC Instruments
    power_switch: "Rocker switch (I/O)"
    rs232: "DB-9 connector (also USB available)"
    digital_ios:
      label: "Digital I/Os (TTL)"
      connectors[7]{name,type}: 
        DIO0,LEMO coaxial
        DIO1,LEMO coaxial
        DIO2,LEMO coaxial
        DIO3,LEMO coaxial
        DIO4,LEMO coaxial
        DIO5,LEMO coaxial
        DIO6,LEMO coaxial
  middle_section:
    label: "Switch Channels 0 and 1"
    output_connector: "Multi-pin circular connector"
    monitors[2]{name,type,impedance}:
      Monitor 0,BNC,"1:100/1MOhm"
      Monitor 1,BNC,"1:100/1MOhm"
    input_connector: "Multi-pin circular connector (700Vpp max, +/-500V max)"
    offsets[2]{name,type,max_voltage}:
      Offset 0,BNC,+/-500V
      Offset 1,BNC,+/-500V
  right_section:
    label: "Switch Channels 2 and 3"
    output_connector: "Multi-pin circular connector"
    monitors[2]{name,type,impedance}:
      Monitor 2,BNC,"1:100/1MOhm"
      Monitor 3,BNC,"1:100/1MOhm"
    input_connector: "Multi-pin circular connector (700Vpp max, +/-500V max)"
    offsets[2]{name,type,max_voltage}:
      Offset 2,BNC,+/-500V
      Offset 3,BNC,+/-500V

specifications:
  master_clock_hz: 100000000
  time_resolution_ns: 10
  register_bit_width: 32
  max_delay_period_s: 42.9
  num_pulsers: 4
  num_pulsers_with_burst: 2
  max_burst_count: 16777216
  num_switches: 4
  num_digital_ios: 7
  num_fans: 3
  num_temp_sensors: 3
  max_stored_configs: 126
  config_name_max_chars: 52
  nvm_data_space_kb: 16
  dio_connector_type: LEMO
  dio_signal_level: "TTL (log.0: 0-0.4V, log.1: 2.4-5.0V)"
  dio_input_impedance: "50 Ohm or 50 kOhm pull-up to +5V"
  dio_output_impedance: "50 Ohm"

timing_formulas:
  oscillator_period:
    formula: "actual_period_ns = (Period_register + 2) * 10"
    offset: 2
    example: "Period=100000 -> (100000+2)*10ns = 1.00002ms ~ 1kHz"
  pulser_delay:
    formula: "actual_delay_ns = (Delay_register + 3) * 10"
    offset: 3
    example: "Delay=1 -> (1+3)*10ns = 40ns minimum"
  pulser_width:
    formula: "actual_width_ns = (Width_register + 2) * 10"
    offset: 2
    example: "Width=50000 -> (50000+2)*10ns = 0.50002ms"
  duty_cycle:
    formula: "duty_cycle = (Width+2) / (Period+2)"
    example: "50000/100000 ~ 50%"
  frequency:
    formula: "frequency_hz = 100e6 / (Period_register + 2)"
    example: "Period=98 -> 100MHz/100 = 1MHz"

communication:
  interface_types[2]: USB 2.0 (Full Speed up to 12 Mbit/s),RS-232
  protocol:
    data_bits: 8
    stop_bits: 2
    parity: even
    default_baud: 9600
    max_baud: 230400
    termination_char: "CR (0x0D)"
    encoding: ASCII
    parameter_format: "hexadecimal uppercase, MSB first"
  handshake:
    dtr_replicated_as: "DSR and DCD"
    rts_replicated_as: CTS
    cts_meaning: "device ready to respond"
    reset_method: "deassert DTR/RTS for >100ms resets to 9600 baud"
  timeout_recommendation_usb_ms: 100
  max_ports: 16
  virtual_port_driver: FTDI
  linux_kernel_support: "3.0.0-19+"
  linux_device_example: /dev/ttyUSB0
  wine_symlink_example: "ln -s /dev/ttyUSB0 ~/.wine/dosdevices/com6"

